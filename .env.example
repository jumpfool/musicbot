API_ID=
API_HASH=
BOT_TOKEN=
SESSION=
LOG_GROUP=

# optional
ADMIN_ID=

# Cookies file for YouTube authentication
# Option 1: Place cookies.txt in the project root directory (default location)
# Option 2: Set COOKIES_FILE=/path/to/cookies.txt to use a custom path
# Option 3: Set YOUTUBE_COOKIES=/path/to/cookies.txt (alternative env var name)
# Get cookies by exporting from your browser using a "Get cookies.txt" extension
COOKIES_FILE=

# YouTube player client to use. Defaults to "mweb" which works with cookies and without
# a JS runtime. "tv_simply" and "tv_downgraded" do NOT support cookies and will be
# skipped automatically when a cookies file is present, leaving no audio formats.
# Set to "default" to let yt-dlp choose (requires a JS runtime for most clients).
# Available: web, web_safari, ios, android, android_vr, tv, tv_simply, tv_downgraded, tv_embedded, mweb
YOUTUBE_CLIENT=mweb

# Optional PO Token for YouTube requests (advanced). Format: "CLIENT.TYPE+TOKEN"
# e.g. YOUTUBE_PO_TOKEN=mweb.player+ABCDEF123...
# See: https://github.com/yt-dlp/yt-dlp/wiki/PO-Token-Guide
YOUTUBE_PO_TOKEN=

# JS runtime for yt-dlp YouTube signature solving. Node.js is pre-installed in the
# Docker image and will be used by default. Set to empty to disable.
# You can also use node:/path/to/node or a JSON dict like {"node": {"path": "/path"}}.
YOUTUBE_JS_RUNTIME=node
