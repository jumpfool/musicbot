API_ID=
API_HASH=
BOT_TOKEN=
SESSION=
LOG_GROUP=

# optional
ADMIN_ID=

# SoundCloud API client IDs (comma-separated, at least one required)
# To obtain a client ID, open soundcloud.com in your browser, open DevTools (F12),
# go to the Network tab, play any track, and look for requests to api-v2.soundcloud.com.
# The client_id query parameter in those requests is your client ID.
# You can provide multiple IDs separated by commas for rotation fallback:
# SOUNDCLOUD_CLIENT_IDS=abc123,def456,ghi789
SOUNDCLOUD_CLIENT_IDS=

# Number of related tracks to queue when radio mode is active (default: 25)
RADIO_BATCH=25
