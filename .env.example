API_ID=
API_HASH=
BOT_TOKEN=
SESSION=
LOG_GROUP=

# optional
ADMIN_ID=

# =============================================================================
# YOUTUBE AUTHENTICATION (REQUIRED FOR MOST USE CASES)
# =============================================================================
# YouTube has implemented anti-bot measures that often require authentication.
# Without cookies, downloads may fail with "Sign in to confirm you're not a bot".
#
# To set up cookies:
# 1. Install a browser extension like "Get cookies.txt" or "EditThisCookie"
# 2. Log into YouTube in your browser
# 3. Export cookies for youtube.com
# 4. Save as 'cookies.txt' in the project root directory
#
# Option 1: Place cookies.txt in the project root directory (default location)
# Option 2: Set COOKIES_FILE=/path/to/cookies.txt to use a custom path
# Option 3: Set YOUTUBE_COOKIES=/path/to/cookies.txt (alternative env var name)
#
# IMPORTANT: Keep your cookies file secure and never share it!
# Cookies expire periodically - re-export them if downloads start failing.
# See: https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
# =============================================================================
COOKIES_FILE=

# YouTube player client to use. Defaults to "mweb" which works well with cookies.
# Available clients: web, web_safari, ios, android, android_vr, tv, tv_simply,
# tv_downgraded, tv_embedded, mweb
# 
# Recommended: mweb (works with cookies, good format availability)
# Note: "tv_simply" and "tv_downgraded" do NOT support cookies
# Note: "ios" and "android" do NOT support cookies (use only as fallback)
YOUTUBE_CLIENT=mweb

# Optional PO Token for YouTube requests (advanced). Format: "CLIENT.TYPE+TOKEN"
# e.g. YOUTUBE_PO_TOKEN=mweb.player+ABCDEF123...
# See: https://github.com/yt-dlp/yt-dlp/wiki/PO-Token-Guide
YOUTUBE_PO_TOKEN=

# JS runtime for yt-dlp YouTube signature solving. Node.js is pre-installed in the
# Docker image and will be used by default. Set to empty to disable.
# You can also use node:/path/to/node or a JSON dict like {"node": {"path": "/path"}}.
YOUTUBE_JS_RUNTIME=node
