# Keep the Docker image small by excluding local files, secrets and development artifacts.

# Environment and secrets
.env
.env.*
!.env.example

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
ENV/
pip-wheel-metadata/
pip-delete-this-directory.txt

# Build / packaging
build/
dist/
*.egg-info/

# Testing / caching
.pytest_cache/
.mypy_cache/
.cache/

# Logs and databases
*.log
*.sqlite3
*.db

# Editor / OS files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
.DS_Store
Thumbs.db
*.swp

# Docker / CI files (exclude if you prefer to copy Dockerfile)
Dockerfile*
docker-compose*.yml

# Git
.git
.gitignore

# Session / key files (common for Telegram / mtproto sessions and TLS keys)
session*
*.session
*.session-jwt
*.pem
*.key
*.crt
*.p12

# Misc
npm-debug.log
yarn-debug.log
yarn-error.log
